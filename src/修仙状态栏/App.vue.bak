<template>
  <div class="cultivation-status-bar">
    <!-- 角色基本信息 -->
    <div class="character-info-section">
      <div class="character-header">
        <div class="character-name">{{ store.data.基本信息.姓名 }}</div>
        <div class="character-race">{{ store.data.基本信息.种族 }}</div>
      </div>

      <!-- 境界与修为 -->
      <div class="cultivation-info">
        <div class="realm-info">
          <span class="realm-label">境界:</span>
          <span class="realm-value">{{ store.data.基本信息.境界.当前境界 }}</span>
        </div>
        <div class="cultivation-progress">
          <div class="progress-bar">
            <div class="progress-fill" :style="{ width: cultivationProgressPercent + '%' }"></div>
          </div>
          <div class="progress-text">
            {{ cultivationProgress }}
          </div>
        </div>
      </div>

      <!-- 寿元与天谴 -->
      <div class="life-info">
        <div class="lifespan-info">
          <span class="lifespan-label">寿元:</span>
          <span class="lifespan-value">{{ store.data.基本信息.寿元.现值 }}/{{ store.data.基本信息.寿元.上限 }}岁</span>
        </div>
        <div v-if="store.data.基本信息.境界.天谴 > 0" class="heavenly-tribulation-info">
          <span class="tribulation-label">天谴:</span>
          <span class="tribulation-value">{{ store.data.基本信息.境界.天谴 }}</span>
        </div>
      </div>
    </div>

    <!-- 状态属性 -->
    <div class="status-attributes-section">
      <div class="attribute-item">
        <div class="attribute-name">气血</div>
        <div class="attribute-value">
          {{ store.data.基本信息.状态.气血.现值 }}/{{ store.data.基本信息.状态.气血.上限 }}
        </div>
      </div>
      <div class="attribute-item">
        <div class="attribute-name">灵力</div>
        <div class="attribute-value">
          {{ store.data.基本信息.状态.灵力.现值 }}/{{ store.data.基本信息.状态.灵力.上限 }}
        </div>
      </div>
      <div class="attribute-item">
        <div class="attribute-name">遁速</div>
        <div class="attribute-value">{{ store.data.基本信息.状态.遁速 }} m/s</div>
      </div>
    </div>

    <!-- 灵根与体质 -->
    <div class="constitution-section">
      <div class="section-title">灵根与体质</div>
      <div class="root-info">
        <div class="root-name">{{ store.data.基本信息.灵根.名称 }}</div>
        <div class="root-elements">
          <span v-for="element in store.data.基本信息.灵根.灵根五行" :key="element" class="element-tag">
            {{ element }}
          </span>
        </div>
      </div>
      <div class="constitution-info">
        <div class="constitution-name">{{ store.data.基本信息.体质.名称 }}</div>
        <div class="constitution-attributes">
          <div class="attribute">
            <span class="attr-label">悟性:</span>
            <span class="attr-value">{{ store.data.基本信息.体质.悟性 }}</span>
          </div>
          <div class="attribute">
            <span class="attr-label">根骨:</span>
            <span class="attr-value">{{ store.data.基本信息.体质.根骨 }}</span>
          </div>
          <div class="attribute">
            <span class="attr-label">气感:</span>
            <span class="attr-value">{{ store.data.基本信息.体质.气感 }}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 当前状态效果 -->
    <div v-if="!_.isEmpty(store.data.基本信息.状态效果)" class="status-effects-section">
      <div class="section-title">状态效果</div>
      <div class="effects-grid">
        <div
          v-for="(effect, name) in store.data.基本信息.状态效果"
          :key="name"
          class="effect-item"
          :class="effect.类型.toLowerCase()"
        >
          <div class="effect-name">{{ name }}</div>
          <div class="effect-details">
            <div class="effect-type">{{ effect.类型 }}</div>
            <div v-if="effect.层数 > 1" class="effect-layer">层数: {{ effect.层数 }}</div>
            <div class="effect-time">{{ effect.剩余时间 }}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 修炼功法 -->
    <div v-if="!_.isEmpty(activeCultivationArts)" class="cultivation-arts-section">
      <div class="section-title">修炼功法</div>
      <div class="arts-list">
        <div v-for="(art, name) in activeCultivationArts" :key="name" class="art-item">
          <div class="art-name">{{ name }}</div>
          <div class="art-quality" :class="'quality-' + art.品质">{{ art.品质 }}品</div>
        </div>
      </div>
    </div>

    <!-- 位置与时间 -->
    <div class="location-time-section">
      <div class="location-info">
        <span class="location-label">位置:</span>
        <span class="location-value"
          >{{ store.data.基本信息.地点.世界 }} - {{ store.data.基本信息.地点.地域 }} -
          {{ store.data.基本信息.地点.具体地点 }}</span
        >
      </div>
      <div class="time-info">
        <span class="time-label">时间:</span>
        <span class="time-value">{{ currentTime }}</span>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import _ from 'lodash';
import { useDataStore } from './store';

const store = useDataStore();

// 计算修为进度百分比
const cultivationProgressPercent = computed(() => {
  const progress = store.data.基本信息.境界.修为进度;
  if (!progress) return 0;

  const [current, total] = progress.split('/').map(Number);
  if (!total || total === 0) return 0;

  return (current / total) * 100;
});

// 格式化修为进度显示
const cultivationProgress = computed(() => {
  return store.data.基本信息.境界.修为进度 || '0/0';
});

// 获取当前运行的修炼功法
const activeCultivationArts = computed(() => {
  const arts = store.data.修炼功法;
  if (!arts) return {};

  const activeArts: Record<string, any> = {};
  for (const [name, art] of Object.entries(arts)) {
    if (art.运行中) {
      activeArts[name] = art;
    }
  }

  return activeArts;
});

// 格式化时间显示
const currentTime = computed(() => {
  const time = store.data.基本信息.时间;
  if (!time) return '';

  return `${time.年}年${time.月}月${time.日}日 ${time.时辰}`;
});
</script>

